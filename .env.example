# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI 小说工厂 - 配置文件
# 复制此文件为 .env 并填入你的实际值
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ━━━━ 飞书应用凭证 ━━━━
# 在飞书开放平台 https://open.feishu.cn 创建应用后获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here

# ━━━━ DeepSeek API ━━━━
# 在 https://platform.deepseek.com 获取
# 支持 deepseek-v4-pro / deepseek-v4-flash
DEEPSEEK_API_KEY=sk-your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# ━━━━ 小说配置 ━━━━
# 飞书 Wiki Token（从 Wiki URL 中获取，如 wiki/XXX 中的 XXX）
NOVEL_WIKI_TOKEN=your_wiki_token_here

# 每批写作章节数（推荐 10）
WRITE_BATCH_SIZE=10

# 每章字数范围
WRITE_MIN_WORDS=2000
WRITE_MAX_WORDS=3000

# 每日发布章节数
PUBLISH_DAILY_COUNT=3

# 每日发布时间（CST，24小时制）
PUBLISH_TIME=12:00

# ━━━━ 部署配置（可选，仅 deploy.py 使用）━━━━
# DEPLOY_HOST=your_server_ip
# DEPLOY_USER=root
# DEPLOY_PASSWORD=your_password
